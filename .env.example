# ================================================================
# CafeQR Delivery Frontend — Environment Variables Template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
#
# Infrastructure summary:
#   - PostgreSQL  → Docker container (primary database)
#   - Redis       → Docker container (session cache, queues)
#   - RabbitMQ    → Docker container (async message broker)
#   - Supabase    → Hosting / realtime subscriptions ONLY
#                   (NOT used as the primary database)
#   - Gmail API   → Transactional email (OAuth2, not SMTP)
#   - Firebase    → FCM push notifications only
# ================================================================

# ---------------------------------------------------------------
# PostgreSQL (Docker)
# Connection string used by pg / postgres npm packages
# ---------------------------------------------------------------
DATABASE_URL=postgresql://cafeqr_user:yourpassword@localhost:5432/cafeqr_delivery
# Individual fields (used by docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cafeqr_delivery
POSTGRES_USER=cafeqr_user
POSTGRES_PASSWORD=yourpassword

# ---------------------------------------------------------------
# Redis (Docker)
# Used for: OTP cache, rate limiting, session tokens, queue state
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# If Redis has a password:
# REDIS_URL=redis://:yourredispassword@localhost:6379
REDIS_OTP_TTL_SECONDS=300

# ---------------------------------------------------------------
# RabbitMQ (Docker)
# Used for: async order events, notification queues
# ---------------------------------------------------------------
RABBITMQ_URL=amqp://cafeqr_user:yourpassword@localhost:5672
# Management UI: http://localhost:15672
RABBITMQ_EXCHANGE=cafeqr_delivery
RABBITMQ_ORDER_QUEUE=delivery_orders
RABBITMQ_NOTIFICATION_QUEUE=delivery_notifications

# ---------------------------------------------------------------
# Supabase — HOSTING & REALTIME ONLY
# Used for: Supabase Realtime channel subscriptions
#           (order tracking live updates on the customer page)
# NOT used as the primary database.
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------
# Gmail API (OAuth2) — Transactional Email
# Used for: OTP emails, order confirmation, receipt emails
# Setup: https://console.cloud.google.com → OAuth2 credentials
# Sender Gmail account must be added as a test user during dev
# ---------------------------------------------------------------
GMAIL_SENDER_ADDRESS=noreply@cafeqr.in
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-gmail-refresh-token
# Access token is auto-refreshed from refresh token — do not hardcode it
# GMAIL_OAUTH_ACCESS_TOKEN=  ← do NOT set, handled at runtime

# ---------------------------------------------------------------
# Firebase (FCM Push Notifications only)
# Client SDK — safe to expose in NEXT_PUBLIC_
# ---------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin SDK — SERVER SIDE ONLY
# Option A: full JSON (recommended for Vercel/Docker env)
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Option B: individual fields
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------
# App Config
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://delivery.cafeqr.in
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210
APP_ENV=development
# NODE_ENV is set automatically by Next.js (development | production)
