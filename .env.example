# ============================================================
# CafeQR Delivery Frontend — Environment Variables Template
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git.
#
# DATABASE: PostgreSQL runs in Docker — accessed via Backend API only.
# The frontend NEVER connects to the DB directly.
# All data operations go through NEXT_PUBLIC_API_BASE_URL.
# ============================================================

# --- Backend API (Spring Boot / Node.js in Docker) ---
# All DB reads/writes go through this — no direct DB connection from frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
# Production:
# NEXT_PUBLIC_API_BASE_URL=https://api.cafeqr.in/api

# --- Firebase (Client SDK — safe to expose, used in browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Firebase Admin SDK (SERVER SIDE ONLY — never expose to browser) ---
# Used in pages/api/ routes to send FCM push notifications
# Option A: full service account JSON as a single env var (recommended)
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON='{"type":"service_account", ...}'
# Option B: individual fields (use if JSON quoting causes issues in your Docker env)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Gmail API OAuth2 (SERVER SIDE ONLY — for sending transactional emails) ---
# These come from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Set Authorised redirect URI to: https://developers.google.com/oauthplayground
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
# Refresh token obtained via OAuth Playground or first-time consent flow
GMAIL_REFRESH_TOKEN=
# The Gmail address that sends emails (must match the OAuth2 account)
GMAIL_SENDER_ADDRESS=noreply@cafeqr.in

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://delivery.cafeqr.in
NEXT_PUBLIC_APP_NAME=CafeQR Delivery
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210

# --- Internal API secret (shared between Next.js API routes and backend) ---
# Set same value in your backend Docker service env
INTERNAL_API_SECRET=change-this-to-a-random-64-char-string

# --- Environment flag ---
APP_ENV=development
# development | staging | production
